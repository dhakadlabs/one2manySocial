{
  "rewrites": [
    {
      "source": "/devto-proxy/:path*",
      "destination": "https://dev.to/:path*"
    },
    {
      "source": "/tumblr-proxy/:path*",
      "destination": "https://www.tumblr.com/:path*"
    },
    {
      "source": "/tumblr-api-proxy/:path*",
      "destination": "https://api.tumblr.com/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}